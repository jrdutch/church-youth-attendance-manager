# ─────────────────────────────────────────────────────────────
# Youth Attendance Manager — configuration
# Copy this file to `.env.local` and fill in your values.
# Lines starting with # are ignored.
# ─────────────────────────────────────────────────────────────

# ── Branding (shown in the app) ──────────────────────────────
# App title in the navbar, login screen, kiosk, and browser tab
NEXT_PUBLIC_APP_NAME=Youth Attendance

# Short name of your parish, used in labels like "Parents are ___ members"
NEXT_PUBLIC_CHURCH_SHORT_NAME=St. Mary's

# Public URL of your app, if you host it online (used in email footers)
# NEXT_PUBLIC_APP_URL=https://attendance.yourchurch.org

# ── Security (REQUIRED) ──────────────────────────────────────
# Random secrets — generate each with:  openssl rand -hex 32
JWT_SECRET=change-me-run-openssl-rand-hex-32
WEBHOOK_SECRET=change-me-run-openssl-rand-hex-32

# ── Weekly email summary (optional) ──────────────────────────
# For Gmail/Google Workspace: create an App Password at
# myaccount.google.com -> Security -> App passwords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@yourchurch.org
# SMTP_PASS=your-app-password
# SUMMARY_EMAIL_TO=you@yourchurch.org

# ── Backups (optional) ───────────────────────────────────────
# Backups also copy to Google Drive automatically if Google Drive
# for desktop is installed. To use a different synced folder:
# GDRIVE_BACKUP_DIR=/path/to/synced/folder
